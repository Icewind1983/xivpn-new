<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.GeoAssetsActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/geoip_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="dlc.dat"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/geoip_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 KB"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/geoip_name" />

                <TextView
                    android:id="@+id/geoip_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="2 days ago"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toEndOf="@+id/geoip_size"
                    app:layout_constraintTop_toBottomOf="@id/geoip_name" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/geoip_download"
                    style="?attr/materialIconButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    app:icon="@drawable/baseline_download_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/geosite_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="geosite.dat"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/geosite_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 MB"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/geosite_name" />

                <TextView
                    android:id="@+id/geosite_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="2 days ago"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toEndOf="@+id/geosite_size"
                    app:layout_constraintTop_toBottomOf="@id/geosite_name" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/geosite_download"
                    style="?attr/materialIconButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    app:icon="@drawable/baseline_download_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
            
            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="6dp" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/rules_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="rules.json"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/rules_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 MB"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rules_name" />

                <TextView
                    android:id="@+id/rules_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="2 days ago"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    app:layout_constraintStart_toEndOf="@+id/rules_size"
                    app:layout_constraintTop_toBottomOf="@id/rules_name" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/rules_download"
                    style="?attr/materialIconButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    app:icon="@drawable/baseline_download_24"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
